# Copy to .env and adjust for your local setup. All values are local-only —
# no proprietary API keys are used anywhere in this project.

# Ollama server address (default if you just run `ollama serve`)
OLLAMA_BASE_URL=http://localhost:11434

# Per-agent model overrides — must be pulled locally first, e.g.:
#   ollama pull llama3.1:8b && ollama pull codeqwen:7b && ollama pull mistral:7b
MANAGER_MODEL=ollama/llama3.1:8b
FRONTEND_MODEL=ollama/codeqwen:7b
BACKEND_MODEL=ollama/codeqwen:7b
QA_MODEL=ollama/mistral:7b

# Where generated project files are written
MAS_OUTPUT_DIR=./output
